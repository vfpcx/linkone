#!/bin/sh
BASEDIR=$(dirname "$0")
export JAVA_HOME="${JAVA_HOME:-/c/Program Files/Android/openjdk/jdk-21.0.8}"
"$JAVA_HOME/bin/java" \
  -classpath "$BASEDIR/.mvn/wrapper/maven-wrapper.jar" \
  -Dmaven.multiModuleProjectDirectory="$BASEDIR" \
  -Dmaven.wrapper.properties="$BASEDIR/.mvn/wrapper/maven-wrapper.properties" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
